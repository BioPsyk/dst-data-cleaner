{
  "key": "prescriptions",
  "title": "Dispensed prescriptions",
  "description": "Contains one row for each prescription made in the Danish healthcare system that was dispensed. In this context, \"dispensed\" means that the patient went to the pharmacy to pick up a medicine that was prescribed to them. This dataset does not contain prescriptions that haven't been dispensed/picked up by the patient.",
  "file_format": {
    "extension": "csv",
    "type": "text",
    "delimiter": ",",
    "quote": "\"",
    "linebreaks": "\n"
  },
  "size": 0,
  "sorted_by": [],
  "columns": {
    "person_id": {
      "index": 0,
      "title": "person_id",
      "description": "Unique (population wide) ID of the person",
      "examples": [
        "",
        "846315",
        "0077131291838"
      ],
      "type": "string",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:PNR"
        }
      ]
    },
    "atc_id": {
      "index": 1,
      "title": "atc_id",
      "description": "WHO-defined Anatomical Therapeutical Chemical code",
      "type": "code",
      "nullable": true,
      "relations": [
        {
          "kind": "code",
          "target": "urn:code:sds:SKS"
        },
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:ATC"
        }
      ]
    },
    "ibnr_id": {
      "index": 2,
      "title": "ibnr_id",
      "description": "Identifier for the dispensing pharmacy",
      "type": "string",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:IBNR"
        }
      ]
    },
    "dispensed_at": {
      "index": 3,
      "title": "dispensed_at",
      "description": "Date when prescription was dispensed",
      "type": "string",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:EKSD"
        }
      ]
    },
    "volume": {
      "index": 4,
      "title": "volume",
      "description": "Number of defined daily doses per package",
      "type": "number",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:VOLUME"
        }
      ]
    },
    "volume_type_code": {
      "index": 5,
      "title": "volume_type_code",
      "description": "Unit used for a dose",
      "type": "string",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:VOLTYPECODE"
        }
      ]
    },
    "pack_size": {
      "index": 6,
      "title": "pack_size",
      "description": "Number of tablets/units per package",
      "type": "string",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:PACKSIZE"
        }
      ]
    },
    "strength": {
      "index": 7,
      "title": "strength",
      "description": "Numerical strength per tablet/unit",
      "type": "number",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:STRNUM"
        }
      ]
    },
    "strength_unit": {
      "index": 8,
      "title": "strength_unit",
      "description": "Unit used for strength",
      "type": "string",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:STRUNIT"
        }
      ]
    },
    "dosage_form": {
      "index": 9,
      "title": "dosage_form",
      "description": "Formulation of the drug",
      "type": "string",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:LMDB:DOSFORM"
        }
      ]
    },
    "source_file": {
      "index": 10,
      "title": "source_file",
      "description": "File that row originates from",
      "type": "string",
      "nullable": false
    }
  }
}
