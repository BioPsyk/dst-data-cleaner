{
  "key": "deaths",
  "title": "Deaths",
  "description": "Contains each death registered in the CPR system, along with the cause, date and mode.",
  "file_format": {
    "extension": "csv",
    "type": "text",
    "delimiter": ",",
    "quote": "\"",
    "linebreaks": "\n"
  },
  "size": 0,
  "sorted_by": ["person_id"],
  "columns": {
    "person_id": {
      "index": 0,
      "title": "person_id",
      "description": "Unique (population wide) ID of the person",
      "examples": [
        "",
        "846315",
        "0077131291838"
      ],
      "type": "string",
      "nullable": false,
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:DODSAARS:PNR"
        },
        {
          "kind": "originates_from",
          "target": "urn:column:dst:DODSAASG:PNR"
        }
      ]
    },
    "deceased_at": {
      "index": 1,
      "title": "deceased_at",
      "description": "Date when the person died",
      "type": "string",
      "nullable": false,
      "examples": [
        "2007-06-04",
        "2008-03-12",
        "1989-08-20"
      ],
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:DODSAARS:D_DODSDTO"
        },
        {
          "kind": "originates_from",
          "target": "urn:column:dst:DODSAASG:D_DODSDATO"
        }
      ]
    },
    "mode": {
      "index": 2,
      "title": "mode",
      "description": "Mode of death (natural, accident, murder, suicide, etc.)",
      "type": "string",
      "nullable": false,
      "examples": [
        "01",
        "99",
        "1"
      ],
      "relations": [
        {
          "kind": "originates_from",
          "target": "urn:column:dst:DODSAARS:C_DODSMAADE"
        },
        {
          "kind": "originates_from",
          "target": "urn:column:dst:DODSAASG:C_DODSMAADE"
        }
      ]
    },
    "cause_1_icd_id": {
      "index": 3,
